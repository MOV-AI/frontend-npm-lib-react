{
  "compilerOptions": {
    "target": "es5", 
    "module": "es2015", 
    "moduleResolution": "node", 
    "jsx": "react",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
